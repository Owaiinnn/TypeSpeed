{
  "name": "typespeed",
  "displayName": "TypeSpeed - Terminal Typing Test",
  "description": "A typing speed test that runs in VS Code's integrated terminal. Practice with code snippets and track your WPM, accuracy, and progress over time.",
  "version": "0.1.0",
  "publisher": "Owaiinnn",
  "author": {
    "name": "Owain"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Owaiinnn/TypeSpeed.git"
  },
  "homepage": "https://github.com/Owaiinnn/TypeSpeed#readme",
  "bugs": {
    "url": "https://github.com/Owaiinnn/TypeSpeed/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "keywords": [
    "typing",
    "wpm",
    "speed",
    "test",
    "practice",
    "code",
    "typing-test",
    "keyboard"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "contributes": {
    "commands": [
      {
        "command": "typespeed.start",
        "title": "TypeSpeed: Start Typing Test"
      },
      {
        "command": "typespeed.history",
        "title": "TypeSpeed: View History"
      },
      {
        "command": "typespeed.clearHistory",
        "title": "TypeSpeed: Clear History"
      }
    ],
    "keybindings": [
      {
        "command": "typespeed.start",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.4.5",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.6"
  }
}
